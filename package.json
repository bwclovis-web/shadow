{
  "name": "shadows",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && npm run typecheck && next build",
    "db:docs": "npx prisma-docs-generator serve",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:serve": "prisma db pull && prisma db push && run-p db:studio db:docs dev",
    "db:studio": "npx prisma studio",
    "db:studio:prod": "node scripts/studio-prod.js",
    "db:fingerprint": "node scripts/db-target-fingerprint.js",
    "db:push:prod": "node scripts/push-prod-schema.js",
    "db:push:prod:dry": "node scripts/push-prod-schema.js --dry-run",
    "db:push:remote:cli": "node scripts/push_local_to_remote_db_cli.js",
    "db:diagnose:perfumes": "node scripts/diagnose-perfume-mismatch.js",
    "db:check:migration": "node scripts/check-migration-status.js",
    "db:backup": "node scripts/backup-database-prisma.js",
    "db:backup:pg": "node scripts/backup-database.js",
    "db:restore": "node scripts/restore-database-prisma.js",
    "db:restore:list": "node scripts/restore-database-prisma.js --list",
    "db:pull:production": "node scripts/pull-production-to-local.js",
    "db:migrate:accelerate": "node scripts/migrate-to-accelerate-fixed.js",
    "db:migrate:accelerate:dry": "node scripts/migrate-to-accelerate-fixed.js --dry-run",
    "db:restore:pg": "node scripts/restore-database.js",
    "db:restore:pg:list": "node scripts/restore-database.js --list",
    "migrate:images": "npx tsx scripts/migrate-images-to-r2.ts",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run typecheck && npm run test",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@conform-to/react": "^1.17.1",
    "@conform-to/zod": "^1.17.1",
    "@gsap/react": "^2.1.2",
    "@langchain/core": "^1.1.29",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/openai": "^1.2.11",
    "@prisma/client": "^6.19.2",
    "@tanstack/react-query": "^5.90.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "date-fns": "^4.1.0",
    "express-rate-limit": "^7.5.1",
    "gsap": "^3.14.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.6",
    "next-intl": "^4.0.0",
    "next-view-transitions": "^0.3.5",
    "papaparse": "^5.5.3",
    "pg": "^8.13.1",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "resend": "^4.8.0",
    "sanitize-html": "^2.14.0",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.14.0",
    "dotenv": "^16.4.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --cache --cache-location ./node_modules/.cache/eslint"
    ]
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not IE 11"
  ]
}
